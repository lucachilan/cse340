<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>Service Categories</h2>
        <ul>
            <% categories.forEach(category=> { %>
                <li class="category-item">
                    <span class="category-name">
                        <%= category.name %>
                    </span>
                </li>
                <% }) %>
        </ul>
    </main>
    <%- include('partials/footer') %>